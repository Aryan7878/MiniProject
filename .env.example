# MongoDB Connection
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/smartcart?retryWrites=true&w=majority

# Authentication
JWT_SECRET=your_super_secret_jwt_key
JWT_EXPIRES_IN=7d

# RapidAPI Configuration (for real-time data)
RAPIDAPI_KEY=your_rapidapi_key_here

# Client URL (for CORS)
CLIENT_URL=https://your-app.vercel.app
PORT=5000
NODE_ENV=production
